// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Shift {
  id                     String   @id
  title                  String
  unit                   String
  facility               String
  role                   String
  startTime              DateTime
  endTime                DateTime
  requiredCertifications String
  priorityLevel          String
  overtimeAllowed        Boolean
  unionRuleset           String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  scenarioRuns ScenarioRun[]
}

model Candidate {
  id                    String   @id
  name                  String
  role                  String
  certifications        String
  unitsQualified        String
  facilitiesQualified   String
  weeklyHours           Float
  overtimeHours         Float
  seniorityScore        Float
  recentAcceptRate      Float
  recentResponseMinutes Float
  attendanceScore       Float
  fatigueRisk           Float
  channelPreferences    String
  isAvailable           Boolean
  recentOutreachCount   Int
  lastShiftEndedAt      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ScenarioRun {
  id                        String   @id @default(cuid())
  shiftId                   String
  predictedFillProbability  Int
  recommendedSequence       String
  rankingSnapshot           String
  managerOverrideCandidateId String?
  managerOverrideReason     String?
  finalOutcome              String?
  createdAt                 DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}